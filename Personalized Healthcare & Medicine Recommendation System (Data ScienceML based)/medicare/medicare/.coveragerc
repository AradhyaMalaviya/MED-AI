# ============================================================================
# Coverage Configuration — MediCare AI
# ============================================================================

[run]
source = .
omit =
    tests/*
    __pycache__/*
    venv/*
    .venv/*
    train_model.py

[report]
show_missing = True
precision = 2
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == .__main__.
    raise NotImplementedError

[html]
directory = htmlcov
